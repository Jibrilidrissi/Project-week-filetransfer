# Redirect direct HTTP access to client/index.php
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^(.*?)/uploads(/|$) [NC]
    RewriteRule ^(.*)$ %1/client/ [R=302,L]
</IfModule>

<IfModule !mod_rewrite.c>
    # Block direct HTTP access as a secure fallback if mod_rewrite is disabled
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</IfModule>
